# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtualenv
venv/
.venv/
env/
.env

# YOLO model weights (downloaded automatically on first run).
# Exception: swiss_detector_v2.pt is bundled — see whitelist below in the
# _models section so a fresh clone has a working multi-class detector.
*.pt
*.pth
*.onnx

# User content (videos, images)
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Source images / timelapse frame folders that may be dropped alongside the project
*.jpg
*.jpeg
*.png
*.bmp
*.tiff
*.webp
*.heic
# Common naming patterns for camera dumps / site folders
[0-9][0-9]-SITE-*/
01-SITE-*/
incoming/

# Custom user-uploaded model weights live in _models/. We bundle exactly
# one curated weights file (CSI_V1.pt — 16-class Construction Site
# Intelligence detector, ~50 MB) so a fresh clone has a working
# multi-class detector out of the box. Other .pt files dropped by the
# user stay local-only.
_models/*
!_models/CSI_V1.pt

# Reference image library — per-class folders with crawler manifests
# and licensed images so users can see what the model thinks each class
# looks like. CSV manifests carry source URL + license per image.
!_reference/**/*.jpg
!_reference/**/*.png
!_reference/**/*.jpeg
!_reference/**/*.csv

# Design handoff bundle and any future design source-of-truth artefacts
_design/
_runs/
_datasets/

# Runtime artifacts
_uploads/
_outputs/
_work/
_data/
_preview*.mp4
_compare*.jpg
*.db
*.db-shm
*.db-wal

# IDE / OS junk
.vscode/
.idea/
*.swp
.DS_Store

# Local diagnostic logs (soak harness, ad-hoc benchmarks)
_soak_log.csv
_bench_*.csv
_profile_*.txt
Thumbs.db

# Logs
*.log

# Claude Code local config
.claude/

# Ruflo / claude-flow runtime + per-project agent config (added 2026-05-01).
# These are operator-machine artifacts created by `ruflo init --full`:
#   .claude-flow/   — V3 runtime: data, logs, sessions, swarm state
#   .mcp.json       — per-project MCP server registration (operator-local)
#   CLAUDE.md       — project-level swarm guidance (auto-generated)
# Keep them OUT of the public arclap-vision-suite repo. Each operator
# runs `ruflo init --full` themselves to regenerate.
.claude-flow/
.mcp.json
CLAUDE.md
.swarm/
