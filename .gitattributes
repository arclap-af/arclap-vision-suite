# Default: let git auto-detect text vs binary
* text=auto

# Force LF line endings on shell scripts so they run on Mac/Linux
# even when authored from Windows.
*.sh text eol=lf

# Force CRLF on Windows-only batch files
*.bat text eol=crlf

# Source code: normalize to LF
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp4 binary
*.pt binary
